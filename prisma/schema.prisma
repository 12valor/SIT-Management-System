// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  STUDENT
  EMPLOYER
  COORDINATOR
}

enum PostingStatus {
  OPEN
  CLOSED
}

enum PlacementType {
  ON_SITE
  REMOTE
  HYBRID
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum LogbookStatus {
  PENDING
  APPROVED
  REJECTED
}

// --- Auth.js Models (NextAuth) ---

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Core Application Models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For Credentials login
  role          UserRole  @default(STUDENT)
  course        String?   // For Students
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Connections
  accounts      Account[]
  sessions      Session[]
  
  // SIT Specific Relations
  company       Company?  @relation(fields: [companyId], references: [id])
  companyId     String?
  
  applications  Application[]
  logbookEntries LogbookEntry[]
  createdPostings SITPosting[]  @relation("EmployerPostings")
  evaluations    SITEvaluation[] @relation("StudentEvaluations")
  documents     SITDocument[]
  notifications Notification[]
}

model Company {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  industry     String
  isVerified   Boolean   @default(false)
  joinedAt     DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  // Relations
  employers    User[]
  postings     SITPosting[]
}

model SITPosting {
  id            String        @id @default(cuid())
  title         String
  description   String        @db.Text
  requiredHours Int           @default(300)
  status        PostingStatus @default(OPEN)
  location      String
  type          PlacementType @default(ON_SITE)
  tags          String[]      @default([])
  postedAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  employer      User          @relation("EmployerPostings", fields: [employerId], references: [id])
  employerId    String
  company       Company       @relation(fields: [companyId], references: [id])
  companyId     String
  applications  Application[]
}

model Application {
  id           String            @id @default(cuid())
  status       ApplicationStatus @default(PENDING)
  notes        String?           @db.Text
  appliedAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // Relations
  posting      SITPosting        @relation(fields: [postingId], references: [id])
  postingId    String
  student      User              @relation(fields: [studentId], references: [id])
  studentId    String

  @@unique([postingId, studentId])
}

model LogbookEntry {
  id           String        @id @default(cuid())
  date         DateTime
  hours        Float
  tasks        String        @db.Text
  status       LogbookStatus @default(PENDING)
  feedback     String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relations
  student      User          @relation(fields: [studentId], references: [id])
  studentId    String
}

model SITEvaluation {
  id               String   @id @default(cuid())
  supervisorName   String
  companyName      String
  technicalSkills  Int
  professionalism  Int
  punctuality      Int
  qualityOfWork    Int
  overallGrade     Float
  comments         String   @db.Text
  recommendForHire Boolean  @default(true)
  submittedAt      DateTime @default(now())

  // Relations
  student          User     @relation("StudentEvaluations", fields: [studentId], references: [id])
  studentId        String
}

model SITDocument {
  id          String   @id @default(cuid())
  name        String
  type        String
  url         String?  // If using external storage like Vercel Blob
  uploadedAt  DateTime @default(now())

  // Relations
  student     User     @relation(fields: [studentId], references: [id])
  studentId   String
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   // e.g., 'LOGBOOK', 'APPLICATION', 'SYSTEM'
  link      String?  // Deep-link to the relevant module
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  @@index([userId])
}
